# F5 XC API Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Tenant
F5XC_API_URL=https://your-tenant.console.ves.volterra.io
F5XC_API_TOKEN=your-api-token
F5XC_TENANT=your-tenant-abcdef12
F5XC_EMAIL=you@example.com

# Application
F5XC_NAMESPACE=your-namespace
F5XC_LB_NAME=your-lb-name
F5XC_DOMAINNAME=app.example.com
F5XC_ROOT_DOMAIN=example.com

# Origin Configuration
F5XC_ORIGIN_POOL=your-origin-pool
F5XC_ORIGIN_IP=192.0.2.1
F5XC_ORIGIN_PORT=443
F5XC_HC_NAME=your-healthcheck

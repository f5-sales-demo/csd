{
  "groups": [
    {
      "label": "F5 XC Tenant",
      "keys": ["F5XC_API_URL", "F5XC_API_TOKEN", "F5XC_EMAIL"]
    },
    {
      "label": "Application",
      "keys": ["F5XC_NAMESPACE", "F5XC_LB_NAME", "F5XC_DOMAINNAME", "F5XC_ROOT_DOMAIN"]
    },
    {
      "label": "Origin Configuration",
      "keys": ["F5XC_ORIGIN_POOL", "F5XC_ORIGIN_IP", "F5XC_ORIGIN_PORT", "F5XC_HC_NAME"]
    }
  ],
  "fields": {
    "F5XC_API_URL": {
      "type": "text",
      "default": "https://example-tenant.console.ves.volterra.io",
      "description": "XC Console API URL"
    },
    "F5XC_API_TOKEN": {
      "type": "text",
      "default": "example-api-token",
      "description": "API credential token"
    },
    "F5XC_EMAIL": {
      "type": "text",
      "default": "user@example.com",
      "description": "CSD notification email"
    },
    "F5XC_NAMESPACE": {
      "type": "text",
      "default": "example-namespace",
      "description": "Namespace"
    },
    "F5XC_LB_NAME": {
      "type": "text",
      "default": "example-lb",
      "description": "HTTP Load Balancer name"
    },
    "F5XC_DOMAINNAME": {
      "type": "text",
      "default": "app.example.com",
      "description": "Domain to protect"
    },
    "F5XC_ROOT_DOMAIN": {
      "type": "text",
      "default": "example.com",
      "description": "Root domain (eTLD+1) for CSD"
    },
    "F5XC_ORIGIN_POOL": {
      "type": "text",
      "default": "csd-origin",
      "description": "Origin pool name"
    },
    "F5XC_ORIGIN_IP": {
      "type": "text",
      "default": "44.232.69.192",
      "description": "Origin server IP"
    },
    "F5XC_ORIGIN_PORT": {
      "type": "text",
      "default": "3000",
      "description": "Origin server port"
    },
    "F5XC_HC_NAME": {
      "type": "text",
      "default": "csd-hc",
      "description": "Healthcheck name"
    }
  }
}

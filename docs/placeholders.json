{
  "groups": [
    {
      "label": "F5 XC Tenant",
      "keys": ["F5XC_API_URL", "F5XC_API_TOKEN", "F5XC_TENANT", "F5XC_EMAIL"]
    },
    {
      "label": "Application",
      "keys": ["F5XC_NAMESPACE", "F5XC_LB_NAME", "F5XC_DOMAINNAME", "F5XC_ROOT_DOMAIN"]
    },
    {
      "label": "Origin Configuration",
      "keys": ["F5XC_ORIGIN_POOL", "F5XC_ORIGIN_IP", "F5XC_ORIGIN_PORT", "F5XC_HC_NAME"]
    }
  ],
  "fields": {
    "F5XC_API_URL": {
      "type": "text",
      "default": "https://f5-sales-demo.console.ves.volterra.io",
      "description": "XC Console API URL"
    },
    "F5XC_API_TOKEN": {
      "type": "text",
      "default": "your-api-token",
      "description": "API credential token"
    },
    "F5XC_TENANT": {
      "type": "text",
      "default": "f5-sales-demo-rljyvvmw",
      "description": "Tenant name"
    },
    "F5XC_EMAIL": {
      "type": "text",
      "default": "admin@example.com",
      "description": "CSD notification email"
    },
    "F5XC_NAMESPACE": {
      "type": "text",
      "default": "bot-defense",
      "description": "Namespace"
    },
    "F5XC_LB_NAME": {
      "type": "text",
      "default": "bot-defense-demo-2",
      "description": "HTTP Load Balancer name"
    },
    "F5XC_DOMAINNAME": {
      "type": "text",
      "default": "botdemo.sales-demo.f5demos.com",
      "description": "Domain to protect"
    },
    "F5XC_ROOT_DOMAIN": {
      "type": "text",
      "default": "f5demos.com",
      "description": "Root domain (eTLD+1) for CSD"
    },
    "F5XC_ORIGIN_POOL": {
      "type": "text",
      "default": "juice-origin",
      "description": "Origin pool name"
    },
    "F5XC_ORIGIN_IP": {
      "type": "text",
      "default": "192.0.2.1",
      "description": "Origin server IP (your backend)"
    },
    "F5XC_ORIGIN_PORT": {
      "type": "text",
      "default": "443",
      "description": "Origin server port"
    },
    "F5XC_HC_NAME": {
      "type": "text",
      "default": "juice-shop-hc",
      "description": "Healthcheck name"
    }
  }
}
